# You can go to https://openrouter.ai/settings/keys to generate a new key and add it here.
# You can change the model in `.ai-commit.config.js` accordingly.

OPENROUTER_API_KEY=sk-example

# RFC-0004: Dialogue Quality Guardrails
# Feature flags — set to "true" to enable, "false" to disable
DIALOGUE_QUALITY_SINGLE_QUESTION_ENABLED=true
DIALOGUE_QUALITY_BREAKTHROUGH_ENABLED=true
DIALOGUE_QUALITY_MISCONCEPTION_ENABLED=true

# Model used for misconception detection (should be fast/cheap)
DIALOGUE_QUALITY_MISCONCEPTION_MODEL=google/gemini-3-flash-preview
