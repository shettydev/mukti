# Mukti — Environment Variables
# Copy this file to .env and fill in your values.
# All variables below have sensible defaults for local development via Docker Compose.

# ── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=dev-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=dev-refresh-secret
JWT_REFRESH_EXPIRES_IN=30d

# ── Session / Security ──────────────────────────────────────────────────────
SESSION_SECRET=dev-session-secret

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=

# ── AI (OpenRouter) ─────────────────────────────────────────────────────────
# Required for Socratic dialogue, canvas insights, and all AI features.
# Get a free key at https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=

# ── Google OAuth (optional) ─────────────────────────────────────────────────
# Leave blank to disable Google sign-in.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/callback

# ── URLs ─────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3001
CORS_ORIGINS=http://localhost:3001
COOKIE_DOMAIN=localhost
API_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000/api/v1

# ── Dialogue Quality Guardrails (RFC-0004) ──────────────────────────────────
DIALOGUE_QUALITY_SINGLE_QUESTION_ENABLED=true
DIALOGUE_QUALITY_BREAKTHROUGH_ENABLED=true
DIALOGUE_QUALITY_MISCONCEPTION_ENABLED=true
DIALOGUE_QUALITY_MISCONCEPTION_MODEL=google/gemini-3-flash-preview
